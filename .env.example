# =============================================================================
# ShieldIaC — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
#
#   cp .env.example .env
#
# NEVER commit the actual .env file to version control.
# All values below are placeholders — replace them before running.
#
# NOTE: All backend env vars use the SHIELDIAC_ prefix (configured in config.py).
# =============================================================================

# =============================================================================
# GENERAL
# =============================================================================

# Runtime environment: development | staging | production
SHIELDIAC_ENVIRONMENT=development

# Enable debug mode (detailed error messages, auto-reload)
SHIELDIAC_DEBUG=true

# Logging level: DEBUG | INFO | WARNING | ERROR
SHIELDIAC_LOG_LEVEL=INFO

# =============================================================================
# DATABASE (PostgreSQL)
# =============================================================================

# PostgreSQL connection string (async driver).
# Local development: postgresql+asyncpg://postgres:postgres@localhost:5432/shieldiac
# Supabase production: postgresql+asyncpg://postgres:<password>@db.<ref>.supabase.co:5432/postgres
SHIELDIAC_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/shieldiac

# =============================================================================
# REDIS
# =============================================================================

# Redis connection string for scan queue and result caching.
# Local development: redis://localhost:6379/0
# Upstash production: rediss://default:<password>@<endpoint>.upstash.io:6379
SHIELDIAC_REDIS_URL=redis://localhost:6379/0

# =============================================================================
# GITHUB APP
# =============================================================================

# GitHub App ID — found on your GitHub App's settings page.
# Example: 123456
SHIELDIAC_GITHUB_APP_ID=

# GitHub App private key (PEM format).
# Generate from GitHub App settings -> Private keys -> Generate a private key.
# Paste the full PEM contents here (escape newlines with \n for single-line).
SHIELDIAC_GITHUB_APP_PRIVATE_KEY=

# Webhook secret for verifying incoming GitHub webhooks (HMAC-SHA256).
# Generate with: openssl rand -hex 32
# Must match the secret configured in your GitHub App settings.
SHIELDIAC_GITHUB_WEBHOOK_SECRET=your-webhook-secret

# =============================================================================
# GITLAB (Optional)
# =============================================================================

# GitLab webhook secret for verifying incoming webhooks.
# Set this in GitLab -> Settings -> Webhooks -> Secret token.
SHIELDIAC_GITLAB_WEBHOOK_SECRET=your-gitlab-secret

# =============================================================================
# OPENAI (AI Fix Suggestions)
# =============================================================================

# OpenAI API key for AI-powered fix suggestions.
# Found at: https://platform.openai.com/api-keys
# Cost: ~$0.006 per scan (cached for 24 hours).
SHIELDIAC_OPENAI_API_KEY=sk-your-openai-api-key

# Model to use for fix generation. gpt-4.1-mini is recommended for cost/quality.
SHIELDIAC_OPENAI_MODEL=gpt-4.1-mini

# Set to false to disable AI fix suggestions entirely.
SHIELDIAC_AI_FIX_ENABLED=true

# =============================================================================
# CLERK (Authentication)
# =============================================================================

# Clerk secret key for backend JWT validation.
# Found at: Clerk Dashboard -> API Keys -> Secret keys
SHIELDIAC_CLERK_SECRET_KEY=

# Clerk publishable key (also needed in frontend as NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY).
# Found at: Clerk Dashboard -> API Keys -> Publishable keys
SHIELDIAC_CLERK_PUBLISHABLE_KEY=

# Clerk webhook secret for user sync events.
# Found at: Clerk Dashboard -> Webhooks -> Signing secret
SHIELDIAC_CLERK_WEBHOOK_SECRET=

# =============================================================================
# STRIPE (Billing)
# =============================================================================

# Stripe secret API key.
# Test mode: sk_test_xxxxx   Live mode: sk_live_xxxxx
SHIELDIAC_STRIPE_SECRET_KEY=

# Stripe publishable key (also needed in frontend).
SHIELDIAC_STRIPE_PUBLISHABLE_KEY=

# Stripe webhook signing secret.
# Found at: Developers -> Webhooks -> your endpoint -> Signing secret
SHIELDIAC_STRIPE_WEBHOOK_SECRET=

# Stripe Price IDs for each subscription tier.
# Create these in Stripe Dashboard -> Products -> Prices.
SHIELDIAC_STRIPE_PRICE_PRO_MONTHLY=price_xxx
SHIELDIAC_STRIPE_PRICE_PRO_YEARLY=price_xxx
SHIELDIAC_STRIPE_PRICE_ENTERPRISE_MONTHLY=price_xxx
SHIELDIAC_STRIPE_PRICE_ENTERPRISE_YEARLY=price_xxx

# =============================================================================
# FRONTEND
# =============================================================================

# These variables are used by Next.js (must start with NEXT_PUBLIC_).
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
