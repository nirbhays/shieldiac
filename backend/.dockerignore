# =============================================================================
# ShieldIaC Backend — Docker Build Exclusions
# =============================================================================
# Prevents unnecessary files from being copied into the Docker image,
# reducing image size and build time.

# Version control
.git
.gitignore

# Python
__pycache__
*.pyc
*.pyo
*.egg-info
.eggs
dist
build
*.egg

# Virtual environments
.venv
venv
env

# Testing & coverage
tests/
htmlcov/
.coverage
coverage.xml
.pytest_cache

# Linting & type checking
.mypy_cache
.ruff_cache

# IDE
.vscode
.idea
*.swp
*.swo

# Environment files (secrets!)
.env
.env.*
!.env.example

# Documentation (not needed in container)
docs/
*.md
LICENSE

# Docker (avoid recursive copy)
Dockerfile
docker-compose.yml
.dockerignore

# OS files
.DS_Store
Thumbs.db
